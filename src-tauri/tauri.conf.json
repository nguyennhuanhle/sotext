{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoText",
  "version": "1.3.0",
  "identifier": "com.sotext.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SoText — Text Similarity Detector",
        "width": 1200,
        "height": 850,
        "minWidth": 900,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
